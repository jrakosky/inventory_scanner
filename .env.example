# Database — MariaDB connection string
# Default targets localhost for local dev (Homebrew MariaDB or host-mapped Docker).
# Docker Compose deploys override this via docker-compose.yml's environment block
# (host "db" resolves only inside the compose network).
DATABASE_URL="mysql://inventory:inventory_pass@localhost:3306/inventory_db"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# Sage Intacct XML Gateway (fallback — legacy API, sender + user credentials)
SAGE_SENDER_ID=""
SAGE_SENDER_PASSWORD=""
SAGE_COMPANY_ID=""
SAGE_USER_ID=""
SAGE_USER_PASSWORD=""
SAGE_ENDPOINT="https://api.intacct.com/ia/xml/xmlgw.phtml"

# Sage Intacct REST API (primary — OAuth 2.0)
# Request these from Sage — they must register INTACCT_REDIRECT_URI against your client.
INTACCT_CLIENT_ID=""
INTACCT_CLIENT_SECRET=""
INTACCT_REDIRECT_URI="http://localhost:3000/api/intacct/callback"
INTACCT_API_URL="https://api.intacct.com/ia/api/v1"
