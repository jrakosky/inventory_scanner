generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  hashedPassword String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  scanLogs             ScanLog[]
  inventoryItems       InventoryItem[]
  cycleCountsCreated   CycleCount[]      @relation("CycleCountCreatedBy")
  cycleCountsAssigned  CycleCount[]      @relation("CycleCountAssignedTo")
  cycleCountEntries    CycleCountEntry[] @relation("CountedByUser")
  todos                Todo[]
  intacctTokens        IntacctToken[]
}

model InventoryItem {
  id          String    @id @default(cuid())
  barcode     String    @unique
  name        String
  description String?   @db.Text
  quantity    Int       @default(0)
  bin         String?
  row         String?
  aisle       String?
  zone        String?
  unit        String?
  category    String?
  condition   Condition @default(GOOD)
  minStock    Int       @default(0)
  costPrice   Decimal?  @db.Decimal(10, 2)
  sageItemId  String?
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scanLogs          ScanLog[]
  cycleCountEntries CycleCountEntry[]

  @@index([barcode])
  @@index([name])
  @@index([category])
  @@index([zone])
  @@index([aisle])
}

model ScanLog {
  id              String        @id @default(cuid())
  barcode         String
  action          ScanAction
  quantityChange  Int           @default(0)
  notes           String?       @db.Text
  scannedBy       User          @relation(fields: [scannedById], references: [id])
  scannedById     String
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId String?
  createdAt       DateTime      @default(now())

  @@index([barcode])
  @@index([createdAt])
  @@index([scannedById])
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  NEW
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum ScanAction {
  CREATED
  INCREMENTED
  DECREMENTED
  UPDATED
  AUDITED
}

/// Warehouse — maps to Intacct's inventory-control/warehouse.
/// Cycle counts (and later, inventory transfers for the staging feature)
/// are scoped to a warehouse. `intacctKey` / `intacctId` are populated
/// once the warehouse is synced from Sage; for local-only dev, seed names.
model Warehouse {
  id          String       @id @default(cuid())
  name        String       @unique
  intacctKey  String?      @unique
  intacctId   String?      @unique
  active      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cycleCounts CycleCount[]
}

/// CycleCount — mirrors Intacct's inventory-control/cycle-count shape.
/// The app handles states up to `counted`; `reconciled` and
/// `adjustmentDate` / `adjustmentPostDate` are populated by Sage after
/// reconciliation in the Sage UI.
model CycleCount {
  id                        String              @id @default(cuid())
  documentNumber            String              @unique
  description               String
  warehouse                 Warehouse           @relation(fields: [warehouseId], references: [id])
  warehouseId               String
  assignedTo                User                @relation("CycleCountAssignedTo", fields: [assignedToId], references: [id])
  assignedToId              String
  createdBy                 User                @relation("CycleCountCreatedBy", fields: [createdById], references: [id])
  createdById               String
  state                     CycleCountState     @default(notStarted)
  excludedAllocatedQuantity Boolean             @default(false)
  showQuantityOnHand        Boolean             @default(false)
  startDate                 DateTime?
  endDate                   DateTime?
  adjustmentDate            DateTime?
  adjustmentPostDate        DateTime?
  intacctKey                String?             @unique
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  entries                   CycleCountEntry[]

  @@index([state])
  @@index([warehouseId])
  @@index([createdAt])
}

/// CycleCountEntry — mirrors Intacct's cycle-count-line. Quantity fields
/// use Decimal(10,2) to match Intacct's string-decimal format.
/// Tracking fields (bin/aisle/zone/row/serial/lot) are snapshot at
/// create time — the physical location at the moment the count was set up.
model CycleCountEntry {
  id               String           @id @default(cuid())
  cycleCount       CycleCount       @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  cycleCountId     String
  inventoryItem    InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  inventoryItemId  String

  // Quantity fields (Intacct: quantity.*)
  onHand           Decimal?         @db.Decimal(10, 2)
  counted          Decimal?         @db.Decimal(10, 2)
  damaged          Decimal?         @db.Decimal(10, 2)
  onHandAtEnd      Decimal?         @db.Decimal(10, 2)
  unitCost         Decimal?         @db.Decimal(10, 2)

  // Tracking snapshot (Intacct: tracking.*)
  bin              String?
  aisle            String?
  zone             String?
  row              String?
  serialNumber     String?
  lotNumber        String?
  expirationDate   DateTime?

  adjustmentReason String?
  lineCountStatus  LineCountStatus  @default(notCounted)
  countedBy        User?            @relation("CountedByUser", fields: [countedById], references: [id])
  countedById      String?
  countedAt        DateTime?
  intacctLineKey   String?          @unique
  createdAt        DateTime         @default(now())

  @@index([cycleCountId])
  @@index([inventoryItemId])
  @@index([lineCountStatus])
}

enum CycleCountState {
  notStarted
  inProgress
  counted
  voided
}

enum LineCountStatus {
  notCounted
  inProgress
  skipped
  counted
}

model Todo {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  priority    TodoPriority @default(MEDIUM)
  status      TodoStatus   @default(TODO)
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([priority])
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TodoStatus {
  TODO
  IN_PROGRESS
  DONE
}

model IntacctToken {
  id            String   @id @default(cuid())
  accessToken   String   @db.Text
  refreshToken  String   @db.Text
  expiresAt     DateTime
  tokenType     String   @default("Bearer")
  scope         String?  @db.Text
  connectedBy   User?    @relation(fields: [connectedById], references: [id])
  connectedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
